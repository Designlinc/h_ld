# Database
DATABASE_URL=

# Auth
JWT_SECRET=

# Tenant routing — the root domain subdomains are resolved against.
# Defaults to h-ld.com if unset, but set it explicitly so local/staging
# environments don't silently fall back to production's domain.
ROOT_DOMAIN=h-ld.com

# Local dev only — lets `vercel dev` resolve a tenant without wildcard DNS.
# Set to an existing organization's subdomain once you've signed one up.
# Leave unset in production.
DEV_ORG_SUBDOMAIN=

# First super-admin account, seeded by `node lib/migrate.js`.
# Change the password after first login; this is only how the account is created.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
