# Database
DATABASE_URL=

# File uploads (business logos, practitioner avatars, background images).
# Vercel sets this automatically once a Blob store is attached to the
# project (Storage tab > Create Database > Blob); only needed manually for
# local dev with `vercel dev`.
BLOB_READ_WRITE_TOKEN=

# Auth
JWT_SECRET=

# Tenant routing — the root domain subdomains are resolved against.
# Defaults to h-ld.com if unset, but set it explicitly so local/staging
# environments don't silently fall back to production's domain.
ROOT_DOMAIN=h-ld.com

# Local dev only — lets `vercel dev` resolve a tenant without wildcard DNS.
# Set to an existing organization's subdomain once you've signed one up.
# Leave unset in production.
DEV_ORG_SUBDOMAIN=

# First super-admin account, seeded by `node lib/migrate.js`.
# Change the password after first login; this is only how the account is created.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Stripe — billing for h_ld. subscriptions (separate from Square, which is
# each practitioner's own payment gateway for THEIR clients).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=price_1TtGWqCrQzY4VbJpA3cwyApW
# Only obtainable after the webhook endpoint is deployed and registered
# in the Stripe dashboard — see Developers > Webhooks.
STRIPE_WEBHOOK_SECRET=
